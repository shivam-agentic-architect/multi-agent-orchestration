rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Projects
    match /projects/{projectId} {
      allow create: if isSignedIn() && isValidId(projectId) && (
        request.resource.data.keys().hasAll(['name', 'description', 'status', 'ownerId', 'createdAt']) &&
        request.resource.data.ownerId == request.auth.uid &&
        request.resource.data.status in ['planning', 'active', 'completed']
      );
      allow get, list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'description', 'status', 'updatedAt'])
      );
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Subcollections
      match /requirements/{id} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
      match /tasks/{id} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
      match /messages/{id} {
        allow read, write: if isSignedIn() && get(/databases/$(database)/documents/projects/$(projectId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
