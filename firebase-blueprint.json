{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A software delivery project managed by the AI Co-Pilot",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["planning", "active", "completed"] },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "status", "ownerId", "createdAt"]
    },
    "Requirement": {
      "title": "Requirement",
      "description": "A functional or technical requirement for the project",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "status": { "type": "string", "enum": ["draft", "approved", "implemented"] },
        "aiAnalysis": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "description", "status", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "A sprint task generated by the Planning Agent",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "requirementId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "assigneeAgent": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in_progress", "review", "done"] },
        "output": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "status", "createdAt"]
    },
    "AgentMessage": {
      "title": "AgentMessage",
      "description": "Internal communication between agents",
      "type": "object",
      "properties": {
        "projectId": { "type": "string" },
        "fromAgent": { "type": "string" },
        "toAgent": { "type": "string" },
        "content": { "type": "string" },
        "payload": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "fromAgent", "content", "timestamp"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Main project metadata"
    },
    "/projects/{projectId}/requirements/{requirementId}": {
      "schema": "Requirement",
      "description": "Requirements list analyzed by Requirement Agent"
    },
    "/projects/{projectId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Backlog and sprint tasks"
    },
    "/projects/{projectId}/messages/{messageId}": {
      "schema": "AgentMessage",
      "description": "Event log for multi-agent coordination"
    }
  }
}
